{
  "manifest_version": 3,
  "name": "Oriel Browser Companion",
  "version": "1.0.0",
  "description": "Reports active browser tabs locally to the Oriel macOS app.",
  "permissions": [
    "tabs",
    "nativeMessaging"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
